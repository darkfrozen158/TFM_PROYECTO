# ╔══════════════════════════════════════════════════════════╗
# ║          BANKING AI AGENT - VARIABLES DE ENTORNO         ║
# ║    Copiar a .env y completar con tus valores reales      ║
# ╚══════════════════════════════════════════════════════════╝

# ── AZURE OPENAI ─────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<tu-recurso>.openai.azure.com/
AZURE_OPENAI_API_KEY=<tu-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── AZURE AI SEARCH (RAG) ────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<tu-servicio>.search.windows.net
AZURE_SEARCH_API_KEY=<tu-search-key>
AZURE_SEARCH_INDEX=banking-knowledge-base

# ── AZURE REDIS CACHE ─────────────────────────────────────────
# Formato: rediss://<nombre>:<clave>@<nombre>.redis.cache.windows.net:6380
AZURE_REDIS_CONNECTION_STRING=rediss://<nombre>:<clave>@<nombre>.redis.cache.windows.net:6380

# ── AZURE CONTENT SAFETY ──────────────────────────────────────
AZURE_CONTENT_SAFETY_ENDPOINT=https://<tu-recurso>.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_API_KEY=<tu-safety-key>

# ── AZURE AD / SEGURIDAD JWT ──────────────────────────────────
AZURE_AD_TENANT_ID=<tu-tenant-id>
AZURE_AD_CLIENT_ID=<tu-client-id>
# AZURE_AD_JWKS_URI se autocalcula si tienes AZURE_AD_TENANT_ID

# ── CORE BANCARIO (MICROSERVICIO INTERNO) ─────────────────────
BANKING_CORE_API_URL=https://core-banking-api.tu-banco.com/api/v1
BANKING_CORE_API_KEY=<tu-core-api-key>

# ── CONFIGURACIÓN DE LA APP ───────────────────────────────────
ENVIRONMENT=development         # development | production
DEMO_MODE=true                  # true solo en desarrollo
ALLOWED_ORIGINS=http://localhost:3000,https://bancamovil.tu-banco.com
AGENT_RATE_LIMIT_PER_MINUTE=30  # peticiones por cliente por minuto
